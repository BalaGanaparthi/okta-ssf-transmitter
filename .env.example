# SSF Transmitter Configuration
# Copy this file to .env and fill in your values

# Your system's issuer URL (should match your Railway deployment URL)
ISSUER=https://your-app.railway.app

# Okta domain (your Okta organization URL)
OKTA_DOMAIN=https://your-org.okta.com

# Key ID for JWKS (must match the kid in your JWKS)
KEY_ID=transmitter-key-1

# Port (Railway will set this automatically)
PORT=8080

# SSF Receiver Configuration
# Port for receiver (default: 8081)
RECEIVER_PORT=8081

# Expected issuer for incoming SETs (Okta domain)
EXPECTED_ISSUER=https://your-org.okta.com

# Okta JWKS URL for signature verification
OKTA_JWKS_URL=https://your-org.okta.com/.well-known/jwks.json

# Receiver identifier
RECEIVER_ID=ssf-receiver-001
